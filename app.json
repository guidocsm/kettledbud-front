{
  "expo": {
    "name": "kettlebud-front",
    "slug": "kettlebud-front",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kettlebud.app"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.kettlebud.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.776323978145-rpg251se92d1bls9tr2m5mkcbugvj79n"
        }
      ]
    ],
    "scheme": "kettlebud"
  }
}
